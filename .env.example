# Firebase の設定値のひな形（仕様書6章）。
# 使い方：
#   1. このファイルをコピーして .env という名前で保存する
#   2. Firebase コンソールで作ったプロジェクトの設定値を、各行の = のうしろに貼り付ける
# ※ .env は秘密情報なので git に載せない（.gitignore で除外済み）。
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=educationappwithcodex20260710
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
